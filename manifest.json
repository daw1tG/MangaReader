{
    "name": "Manga Reader",
    "description": "This extension scrapes pages of manga/comic websites and reformats them for easy reading",
    "version": "1.8.24",
    "manifest_version": 3,

    "action": {
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },

    "host_permissions": ["*://*/*"],
    "permissions": ["scripting", "storage"],

    "background": {
        "service_worker": "background.js"
    }
}