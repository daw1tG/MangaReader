{
    "name": "Manga Reader",
    "description": "",
    "version": "1.8.24",
    "manifest_version": 3,

    "action": {
        "default_icon": {
            "16": "images/icon-16.png",
            "32": "images/icon-32.png",
            "48": "images/icon-48.png",
            "128": "images/icon-128.png"
        }
    },

    "host_permissions": ["*://*/*"],
    "permissions": ["scripting", "storage"],

    "background": {
        "service_worker": "background.js"
    }
}